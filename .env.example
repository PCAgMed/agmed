# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Override env tag on logs/dashboards independently of NODE_ENV.
# Common values: development | staging | production
# APP_ENV=staging
# APP_RELEASE=                # release identifier (git sha / version)

# Database (PostgreSQL — Docker container on VPS or local Compose)
DATABASE_URL=postgresql://clinica:password@localhost:5432/clinica_agenda

# Auth.js v5 (NextAuth)
AUTH_SECRET=                  # generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Observability (Grafana / Loki — bring up with: docker compose --profile observability up -d)
# When LOKI_URL is set, the app pushes structured logs to Loki via pino-loki
# in addition to stdout. Leave empty to disable Loki push (stdout only).
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3110
# LOKI_USERNAME=              # optional basic auth
# LOKI_PASSWORD=
# LOG_LEVEL=info              # trace | debug | info | warn | error | fatal

# AGM-8 verification — enables /api/debug/throw. NEVER set true in production.
DEBUG_THROW_ENABLED=true

# WhatsApp Business API (placeholder — AGM scope TBD)
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# PIX / Payments (placeholder — AGM scope TBD)
# PIX_API_KEY=
# PIX_CLIENT_ID=
# PIX_CLIENT_SECRET=
