# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL — Docker container on VPS or local Compose)
DATABASE_URL=postgresql://clinica:password@localhost:5432/clinica_agenda

# Auth.js v5 (NextAuth)
AUTH_SECRET=                # generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Observability (Grafana / Loki — optional in local dev)
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100

